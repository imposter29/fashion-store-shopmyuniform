# Environment: development | production
NODE_ENV=development

# Port the API server listens on
PORT=5000

# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/stylecart

# Secret used to sign JWTs — MUST be a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_secret

# Allowed browser origin(s) for CORS in a SPLIT deploy (frontend on Vercel,
# API on Render). Comma-separate multiple (production + preview) URLs.
# Required for the split deploy so the cross-origin cookie is accepted.
# CLIENT_ORIGIN=https://stylecart.vercel.app,https://stylecart-git-main-you.vercel.app
