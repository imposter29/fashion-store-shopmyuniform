{
  "name": "stylecart",
  "version": "1.0.0",
  "description": "StyleCart — MERN fashion e-commerce monorepo",
  "private": true,
  "scripts": {
    "server": "node server/server.js",
    "server:dev": "nodemon server/server.js",
    "client": "npm run dev --prefix client",
    "dev": "concurrently -n server,client -c blue,green \"npm run server:dev\" \"npm run client\"",
    "seed": "node server/seed.js",
    "install-all": "npm install && npm install --prefix client",
    "build": "npm install --prefix client && npm run build --prefix client",
    "start": "NODE_ENV=production node server/server.js"
  },
  "keywords": [
    "mern",
    "ecommerce",
    "fashion"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.1.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  }
}
